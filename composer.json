{
    "name": "toflar/fast-set",
    "description": "Provides the means to create memory-efficient precompiled sets with very fast fingerprint lookups",
    "keywords": ["dictionary", "set", "lookup", "binary", "hash", "memory", "fingerprint"],
    "type": "library",
    "require":  {
        "php": "^8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5 || ^11.0 || ^12.5",
        "terminal42/code-quality-tools": "@dev"
    },
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Toflar\\FastSet\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Toflar\\FastSet\\Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "Yanick Witschi",
            "email": "yanick.witschi@terminal42.ch"
        }
    ],
    "config": {
        "allow-plugins": {
            "terminal42/code-quality-tools": true
        }
    },
    "scripts": {
        "cs-fixer": "@php vendor/terminal42/code-quality-tools/tools/ecs/vendor/bin/ecs check src tests bin --config vendor/terminal42/code-quality-tools/tools/ecs/config.php --fix --ansi",
        "rector": "@php vendor/terminal42/code-quality-tools/tools/rector/vendor/bin/rector process src tests bin --config vendor/terminal42/code-quality-tools/tools/rector/config.php --ansi",
        "phpstan": "@php vendor/terminal42/code-quality-tools/tools/phpstan/vendor/bin/phpstan analyze src tests bin --configuration vendor/terminal42/code-quality-tools/tools/phpstan/config.php --ansi",
        "composer-dependencies": "@php vendor/terminal42/code-quality-tools/tools/composer-dependency-analyser/vendor/bin/composer-dependency-analyser --config vendor/terminal42/code-quality-tools/tools/composer-dependency-analyser/config.php",
        "code-quality": [
            "@cs-fixer",
            "@rector",
            "@phpstan",
            "@composer-dependencies"
        ],
        "ci-code-quality": "@code-quality"
    }
}
